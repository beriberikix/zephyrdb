# ZephyrDB Kconfig (first pass)
# Scope: Core + KV + TS modules.
# Document/FlatBuffers module knobs are intentionally deferred.

menuconfig ZEPHYRDB
	bool "ZephyrDB embedded multi-model database"
	depends on FLASH || BOARD_NATIVE_SIM
	help
	  Enable ZephyrDB core services for memory-constrained systems.
	  First pass includes Core, KV (NVS) and TS (LittleFS).

if ZEPHYRDB

config ZDB_CORE
	bool "Enable ZephyrDB Core"
	default y
	help
	  Enables core engine pieces: storage abstraction hooks,
	  cursor framework, and slab-based pool interfaces.

config ZDB_KV
	bool "Enable ZephyrDB KV module"
	default y
	depends on ZDB_CORE
	help
	  Enables key-value APIs.

choice ZDB_KV_BACKEND
	prompt "KV backend"
	default ZDB_KV_BACKEND_NVS
	depends on ZDB_KV
	help
	  Selects the Zephyr storage backend used by ZephyrDB KV APIs.

config ZDB_KV_BACKEND_NVS
	bool "NVS"
	depends on NVS
	help
	  Use Non-Volatile Storage (NVS) as the KV backend.

config ZDB_KV_BACKEND_ZMS
	bool "ZMS"
	depends on ZMS
	help
	  Use Zephyr Memory Storage (ZMS) as the KV backend.

endchoice

config ZDB_TS
	bool "Enable ZephyrDB Time-Series module"
	default y
	depends on ZDB_CORE && (FILE_SYSTEM || FCB)
	help
	  Enables time-series APIs.

choice ZDB_TS_BACKEND
	prompt "TS backend"
	default ZDB_TS_BACKEND_LITTLEFS
	depends on ZDB_TS
	help
	  Selects the storage backend used by ZephyrDB TS APIs.

config ZDB_TS_BACKEND_LITTLEFS
	bool "LittleFS"
	depends on FILE_SYSTEM
	help
	  Use LittleFS append-log files for time-series storage.

config ZDB_TS_BACKEND_FCB
	bool "FCB"
	depends on FCB
	help
	  Use Flash Circular Buffer (FCB) for time-series storage.

endchoice

menu "Core Boundaries"
	depends on ZDB_CORE

config ZDB_MAX_KEY_LEN
	int "Maximum key length"
	range 8 128
	default 48
	help
	  Upper bound for user-facing keys (excluding trailing NUL).

config ZDB_MAX_OPEN_CURSORS
	int "Maximum open cursors"
	range 1 64
	default 4
	help
	  Limits concurrent iterators across all enabled modules.

config ZDB_SCAN_YIELD_EVERY_N
	int "Yield after N scan iterations"
	range 1 4096
	default 64
	help
	  Cooperative scheduling interval for long scans.

config ZDB_CORE_SLAB_BLOCK_SIZE
	int "Core slab block size (bytes)"
	range 32 2048
	default 128

config ZDB_CORE_SLAB_BLOCK_COUNT
	int "Core slab block count"
	range 1 256
	default 16

config ZDB_CURSOR_SLAB_BLOCK_SIZE
	int "Cursor slab block size (bytes)"
	range 32 2048
	default 96

config ZDB_CURSOR_SLAB_BLOCK_COUNT
	int "Cursor slab block count"
	range 1 256
	default 8

endmenu

menu "KV Boundaries"
	depends on ZDB_KV

config ZDB_KV_IO_SLAB_BLOCK_SIZE
	int "KV IO slab block size (bytes)"
	range 16 1024
	default 128

config ZDB_KV_IO_SLAB_BLOCK_COUNT
	int "KV IO slab block count"
	range 1 256
	default 8

endmenu

menu "TS Boundaries"
	depends on ZDB_TS

config ZDB_TS_STREAM_NAME_MAX_LEN
	int "TS stream name max length"
	range 8 64
	default 24

config ZDB_TS_INGEST_BUFFER_BYTES
	int "TS ingest buffer bytes"
	range 64 16384
	default 1024
	depends on ZDB_TS_BACKEND_LITTLEFS
	help
	  Upper bound for RAM staging prior to sequential flush.

config ZDB_TS_FLUSH_QUEUE_DEPTH
	int "TS flush queue depth"
	range 1 128
	default 8
	depends on ZDB_TS_BACKEND_LITTLEFS

config ZDB_TS_MAX_AGG_POINTS
	int "TS aggregation max points"
	range 1 1048576
	default 4096
	depends on ZDB_TS_BACKEND_LITTLEFS

config ZDB_TS_INGEST_SLAB_BLOCK_SIZE
	int "TS ingest slab block size (bytes)"
	range 16 2048
	default 64

config ZDB_TS_INGEST_SLAB_BLOCK_COUNT
	int "TS ingest slab block count"
	range 1 512
	default 32

config ZDB_TS_AUTO_RECOVER_ON_OPEN
	bool "Auto recover TS stream on open"
	default y
	depends on ZDB_TS_BACKEND_LITTLEFS
	help
	  If enabled, zdb_ts_open() scans and truncates trailing corrupt or
	  partial records automatically.

config ZDB_TS_MAX_RECOVERY_TRUNCATE_BYTES
	int "Maximum bytes recover may truncate"
	range 0 1048576
	default 4096
	depends on ZDB_TS_BACKEND_LITTLEFS
	help
	  Safety cap for automatic recovery truncation. Set to 0 to disable
	  truncation cap checks.

config ZDB_TS_FCB_FLASH_AREA_ID
	int "TS FCB flash area ID"
	range 0 255
	default 0
	depends on ZDB_TS_BACKEND_FCB
	help
	  Flash area ID passed to fcb_init() for TS backend when using FCB.

config ZDB_TS_FCB_SECTOR_COUNT
	int "TS FCB sector count"
	range 2 64
	default 4
	depends on ZDB_TS_BACKEND_FCB
	help
	  Number of sectors provided to the FCB instance.

config ZDB_TS_MULTISTREAM
	bool "Enable multi-stream time-series support (Stage 2.5)"
	default n
	depends on ZDB_TS
	help
	  If enabled, allows managing multiple independent time-series streams
	  simultaneously with cross-stream operations (batch flush, unified stats,
	  aggregation across streams).

config ZDB_TS_MAX_CONCURRENT_STREAMS
	int "Maximum concurrent TS streams"
	range 2 32
	default 8
	depends on ZDB_TS_MULTISTREAM
	help
	  Upper bound for simultaneously open streams in multi-stream mode.

config ZDB_TS_MAX_DISCOVERABLE_STREAMS
	int "Maximum streams during enumeration"
	range 1 128
	default 16
	depends on ZDB_TS_MULTISTREAM
	help
	  Limits the number of streams discovered and returned when
	  enumerating available streams.

endmenu

menu "Storage Integration"

config ZDB_USE_DT_CHOSEN_STORAGE
	bool "Discover storage from zephyr,storage chosen node"
	default y
	help
	  If enabled, ZephyrDB resolves storage layout from the
	  zephyr,storage chosen node at runtime/init.

config ZDB_LFS_MOUNT_POINT
	string "LittleFS mount point"
	default "/lfs"
	help
	  Mount path used by TS module for append-log files.

config ZDB_TS_DIRNAME
	string "TS stream directory name"
	default "zdb"
	depends on ZDB_TS && ZDB_TS_BACKEND_LITTLEFS
	help
	  Directory under ZDB_LFS_MOUNT_POINT used for time-series stream
	  files. This namespaces ZephyrDB TS files away from other files that
	  may share the same filesystem mount point.

endmenu

menu "Diagnostics"

config ZDB_EVENTING
	bool "Enable ZephyrDB event emitter/listener hooks"
	default n
	depends on ZDB_KV
	help
	  Enables lightweight local mutation events for KV operations.
	  This feature is intended for in-process listeners and does not
	  provide durability or distributed delivery guarantees.

config ZDB_EVENTING_ZBUS
	bool "Publish KV events to zbus"
	default n
	depends on ZDB_EVENTING && ZBUS
	help
	  Publishes ZephyrDB KV mutation events to a zbus channel.
	  This is an optional adapter layer and does not change write-path
	  behavior if publish fails.

config ZDB_STATS
	bool "Enable ZephyrDB statistics counters"
	default n

config ZDB_DEBUG
	bool "Enable ZephyrDB debug checks"
	default n

endmenu

config ZDB_SHELL
	bool "Enable ZephyrDB shell interface"
	depends on SHELL
	help
	  Enables a compact Zephyr shell interface under the 'zdb' command
	  for common development operations.

menu "Stage 2 (Experimental)"

config ZDB_FLATBUFFERS
	bool "Enable FlatBuffers helper APIs"
	default n
	depends on ZDB_TS && FLATCC
	help
	  Enables Stage 2 bootstrap helpers that export TS samples using
	  FlatCC runtime primitives. Requires flatcc-zephyr module with
	  CONFIG_FLATCC enabled.

config ZDB_DOC
	bool "Enable document model (Stage 3)"
	default n
	depends on ZDB_FLATBUFFERS && (FILE_SYSTEM || NVS || ZMS)
	help
	  Enables semi-structured document APIs built on FlatBuffers.
	  Supports variable-length strings, nested objects, and dynamic queries
	  on document properties. Can use LittleFS, NVS, or ZMS as backend.

choice ZDB_DOC_BACKEND
	prompt "Document storage backend"
	default ZDB_DOC_BACKEND_LITTLEFS
	depends on ZDB_DOC

config ZDB_DOC_BACKEND_LITTLEFS
	bool "LittleFS (filesystem-based)"
	depends on FILE_SYSTEM
	help
	  Store documents as individual files in a LittleFS filesystem.
	  Offers native directory structure and efficient queries via directory scanning.
	  Requires sufficient flash or external storage for filesystem overhead.

config ZDB_DOC_BACKEND_NVS
	bool "NVS (flash key-value)"
	depends on NVS
	help
	  Store documents as serialized blobs in NVS entries.
	  Enables document storage on boards with limited flash (no filesystem).
	  Queries require full scan and deserialization of all entries.

config ZDB_DOC_BACKEND_ZMS
	bool "ZMS (Zephyr Memory Storage)"
	depends on ZMS
	help
	  Store documents as serialized blobs in ZMS entries.
	  Better wear-leveling and larger ID space than NVS.
	  Queries require full scan and deserialization of all entries.

endchoice

menu "Document Model (Stage 3)"
	depends on ZDB_DOC

config ZDB_DOC_MAX_FIELD_NAME_LEN
	int "Max document field name length"
	range 8 128
	default 32
	help
	  Maximum length for field names in documents (excluding NUL).

config ZDB_DOC_MAX_STRING_LEN
	int "Max document string field length"
	range 16 65536
	default 256
	help
	  Maximum size of string-type fields within documents.

config ZDB_DOC_MAX_BYTES_LEN
	int "Max document bytes field length"
	range 16 1048576
	default 4096
	help
	  Maximum size of bytes-type fields within documents.

config ZDB_DOC_MAX_FIELD_COUNT
	int "Max fields per document"
	range 1 256
	default 32
	help
	  Upper bound for number of fields in a single document.

config ZDB_DOC_MAX_NESTED_DEPTH
	int "Max nesting depth for document objects"
	range 1 16
	default 4
	help
	  Maximum depth for nested object hierarchies.

config ZDB_DOC_SLAB_BLOCK_SIZE
	int "Document field slab block size (bytes)"
	range 64 2048
	default 256

config ZDB_DOC_SLAB_BLOCK_COUNT
	int "Document field slab block count"
	range 1 256
	default 16

config ZDB_DOC_MAX_SERIALIZED_SIZE
	int "Max serialized document size (bytes)"
	range 256 65536
	default 1024
	depends on (ZDB_DOC_BACKEND_NVS || ZDB_DOC_BACKEND_ZMS)
	help
	  Maximum size for a serialized document blob when using NVS or ZMS backend.
	  Larger documents are rejected at save time to prevent entry overhead.
	  For LittleFS backend, this limit is not enforced (filesystem handles arbitrary sizes).

config ZDB_DOC_MANIFEST_MAX_ENTRIES
	int "Max documents in manifest cache"
	range 8 1024
	default 64
	depends on (ZDB_DOC_BACKEND_NVS || ZDB_DOC_BACKEND_ZMS)
	help
	  Maximum number of (collection, document_id) pairs cached in RAM
	  when using NVS or ZMS backend. Queries enumerate manifest to discover documents.

endmenu

endmenu

endif # ZEPHYRDB
